<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="AomNetworkHook" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/AomNetworkHook" prefix_auto="0" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-DBUILD_DLL" />
					<Add option="-g" />
					<Add option="-masm=intel" />
					<Add directory="MinHook/include" />
					<Add directory="MinHook/src" />
					<Add directory="MinHook/src/hde" />
				</Compiler>
				<Linker>
					<Add option="-static" />
					<Add option="-static-libgcc" />
					<Add option="-static-libstdc++" />
					<Add library="iphlpapi" />
					<Add library="ws2_32" />
					<Add library="kernel32" />
					<Add library="user32" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/AomNetworkHook" prefix_auto="0" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="3" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Option createStaticLib="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-DBUILD_DLL" />
					<Add option="-O2" />
					<Add option="-masm=intel" />
					<Add directory="MinHook/include" />
					<Add directory="MinHook/src" />
					<Add directory="MinHook/src/hde" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add option="-static" />
					<Add option="-static-libgcc" />
					<Add option="-static-libstdc++" />
					<Add library="iphlpapi" />
					<Add library="ws2_32" />
					<Add library="kernel32" />
					<Add library="user32" />
				</Linker>
			</Target>
		</Build>
		<Unit filename="main.cpp" />
		<Unit filename="main.h" />
		<Unit filename="MinHook/include/MinHook.h" />
		<Unit filename="MinHook/src/buffer.c" />
		<Unit filename="MinHook/src/hook.c" />
		<Unit filename="MinHook/src/trampoline.c" />
		<Unit filename="MinHook/src/hde/hde32.c" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
